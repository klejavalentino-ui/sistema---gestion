rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isProductValid(data) {
      return data.keys().hasAll(['sku', 'name', 'cost', 'stock']) &&
             data.sku is string && data.sku.size() <= 100 &&
             data.name is string && data.name.size() <= 200 &&
             data.cost is number &&
             data.stock is number;
    }

    function isSaleValid(data) {
      return data.keys().hasAll(['date', 'total', 'items']) &&
             data.date is string && data.date.size() <= 100 &&
             data.total is number &&
             data.items is list && data.items.size() <= 100;
    }

    match /products/{productId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(productId) && isProductValid(incoming());
      allow update: if isSignedIn() && isValidId(productId) && isProductValid(incoming());
      allow delete: if isSignedIn() && isValidId(productId);
    }

    match /sales/{saleId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(saleId) && isSaleValid(incoming());
      allow update: if isSignedIn() && isValidId(saleId) && isSaleValid(incoming());
      allow delete: if isSignedIn() && isValidId(saleId);
    }
  }
}
